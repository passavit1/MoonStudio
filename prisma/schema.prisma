// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Platform {
  id        Int      @id @default(autoincrement())
  name      String   @unique // "TikTok", "Shopee", "Lazada"
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                      Int         @id @default(autoincrement())
  platform                Platform    @relation(fields: [platformId], references: [id])
  platformId              Int
  externalOrderId         String      @unique // ID from the CSV
  status                  String      // e.g., "Completed", "Cancelled", "To Ship"
  cancelationType         String?     // e.g., "Cancel", "Return"
  subtotalBeforeDiscount  Float       @default(0) // Real product value (sum of SKU Subtotal Before Discount)
  subtotal                Float       @default(0) // Sum of SKU Subtotal After Discount (what customer sees)
  shippingFee             Float       @default(0)
  orderAmount             Float       @default(0) // Total after discounts (what customer paid)
  settlementAmount        Float?      // What was actually received (from income/settlement file)
  buyerUsername           String?
  province                String?
  paymentMethod           String?
  createdTime             DateTime?
  paidTime                DateTime?
  shippedTime             DateTime?   // When order was shipped
  items                   OrderItem[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  order           Order    @relation(fields: [orderId], references: [id])
  orderId         Int
  skuId           String?
  productName     String
  variation       String?
  quantity        Int      @default(1)
  originalPrice   Float    @default(0)
  platformDiscount Float    @default(0)
  sellerDiscount   Float    @default(0)
  subtotal        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orderId, skuId])
}

model FileImportMetadata {
  id               Int      @id @default(autoincrement())
  fileName         String   @unique
  lastImportedAt   DateTime @default(now()) @updatedAt
  recordCount      Int      @default(0)
  status           String   @default("COMPLETED") // PENDING, COMPLETED, FAILED
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
